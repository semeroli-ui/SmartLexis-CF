rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, email, name, role, createdAt
    //
    // Collection: exams
    // Fields: studentId, studentName, choice, modernReading, classicReading, composition, total, date
    //
    // Collection: writingAnalyses
    // Fields: studentId, images, transcription, analysis, score, date
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isTeacher() {
      return isAuthenticated() && getUserData().role == 'teacher';
    }

    function isStudent() {
      return isAuthenticated() && getUserData().role == 'student';
    }

    match /users/{uid} {
      allow read: if isAuthenticated();
      allow write: if isOwner(uid);
    }

    match /exams/{examId} {
      allow read: if isTeacher() || (isStudent() && request.auth.uid == resource.data.studentId);
      allow create: if isTeacher();
      allow update, delete: if isTeacher();
    }

    match /writingAnalyses/{analysisId} {
      allow read: if isTeacher() || (isStudent() && request.auth.uid == resource.data.studentId);
      allow create: if isStudent() && request.auth.uid == request.resource.data.studentId;
      allow update, delete: if isTeacher() || (isStudent() && request.auth.uid == resource.data.studentId);
    }
  }
}
